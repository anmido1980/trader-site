---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';
import { getPosts } from '../../utils/posts';

export async function getStaticPaths() {
  const posts = await getPosts();
  const tagSet = new Set(posts.flatMap((p) => p.tags));
  return Array.from(tagSet).map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;
const allPosts = await getPosts();
const posts = allPosts.filter((p) => p.tags.includes(tag));
---

<Layout
  title={`#${tag} · Материалы · Портфельный инвестор`}
  description={`Материалы по теме ${tag}`}
  canonical={`/tags/${tag}/`}
>
  <Header />
  <main id="main" class="posts-page">
    <div class="container">
      <header class="posts-page__head">
        <span class="eyebrow">// Тег</span>
        <h1>#{tag}</h1>
        <p class="posts-page__lead">
          {posts.length} {posts.length === 1 ? 'материал' : posts.length < 5 ? 'материала' : 'материалов'} по теме.
        </p>
      </header>

      <div class="posts-page__grid">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .posts-page {
    padding: var(--space-6) 0;
    background: var(--color-bg-page);
    min-height: 60vh;
  }
  .posts-page__head {
    margin-bottom: var(--space-4);
  }
  .posts-page__head h1 {
    font-size: var(--font-size-3xl);
    margin: var(--space-3) 0 0;
    line-height: 1.15;
  }
  .posts-page__lead {
    color: var(--color-text-secondary);
    font-size: var(--font-size-md);
    margin-top: var(--space-2);
  }
  .posts-page__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  @media (max-width: 1000px) {
    .posts-page__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
