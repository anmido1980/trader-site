---
import type { Post } from '../utils/posts';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const date = new Date(post.publishedAt).toLocaleDateString('ru-RU', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<article class="post-card" data-reveal>
  <a href={`/posts/${post.slug}/`} class="post-card__link" aria-label={post.title}>
    <img
      src={post.image}
      alt=""
      width="400"
      height="225"
      loading="lazy"
      class="post-card__image"
    />
  </a>
  <div class="post-card__body">
    <time class="post-card__date" datetime={post.publishedAt}>{date}</time>
    <h3 class="post-card__title">
      <a href={`/posts/${post.slug}/`}>{post.title}</a>
    </h3>
    <p class="post-card__summary">{post.summary}</p>
    {post.tags.length > 0 && (
      <div class="post-card__tags">
        {post.tags.slice(0, 3).map((tag) => (
          <a href={`/tags/${tag}/`} class="post-card__tag">#{tag}</a>
        ))}
      </div>
    )}
  </div>
</article>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg-panel);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-panel);
    transition: transform var(--t-fast), box-shadow var(--t-fast);
  }
  .post-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-panel-hover, 0 8px 24px rgba(0, 0, 0, 0.08));
  }
  .post-card__link {
    display: block;
    line-height: 0;
  }
  .post-card__image {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }
  .post-card__body {
    padding: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .post-card__date {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .post-card__title {
    font-size: var(--font-size-md);
    line-height: 1.3;
    margin: 0;
  }
  .post-card__title a {
    color: var(--color-text-primary);
    text-decoration: none;
  }
  .post-card__title a:hover {
    color: var(--color-accent);
  }
  .post-card__summary {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin: 0;
  }
  .post-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: auto;
    padding-top: 8px;
  }
  .post-card__tag {
    font-size: var(--font-size-xs);
    color: var(--color-accent);
    text-decoration: none;
  }
  .post-card__tag:hover {
    text-decoration: underline;
  }
</style>
