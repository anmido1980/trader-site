---
import market from '../data/market.json';

const nav = [
  { href: '/#top', label: 'Обзор' },
  { href: '/#topics', label: 'Темы' },
  { href: '/#rubrics', label: 'Рубрики' },
  { href: '/#subscribe', label: 'Подписка' },
  { href: '/#about', label: 'О канале' },
];

const updatedAt = new Date(market.updatedAt).toLocaleString('ru-RU', {
  day: '2-digit',
  month: '2-digit',
  hour: '2-digit',
  minute: '2-digit',
});
---

<header class="topbar" id="site-header">
  <div class="topbar__inner container">
    <a href="https://anmido.io/" class="topbar__brand" aria-label="Портфельный инвестор — на главную">
      <span class="topbar__logo" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none">
          <path d="M3 18 L9 11 L13 14 L21 5" stroke="#fff" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"/>
          <circle cx="21" cy="5" r="1.5" fill="#9bd1ff"/>
        </svg>
      </span>
      <span class="topbar__brand-text">
        <span class="topbar__brand-name">Портфельный инвестор</span>
        <span class="topbar__brand-sub">Portfolio Investor · PI</span>
      </span>
    </a>

    <button class="topbar__burger" type="button" aria-label="Меню" aria-expanded="false" data-burger>
      <span></span><span></span><span></span>
    </button>

    <nav class="topbar__nav" aria-label="Основная навигация">
      <ul>
        {nav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="topbar__actions">
      <span class="topbar__status">
        <span class="live-dot" aria-hidden="true"></span>
        <span class="topbar__status-text" id="topbar-status-time">Рынок · {updatedAt} MSK</span>
      </span>
      <a href="/#subscribe" class="btn btn--primary btn--sm">Подписаться</a>
    </div>
  </div>
</header>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: linear-gradient(180deg, #2773c2 0%, #1f5fa8 100%);
    color: #ffffff;
    border-bottom: 1px solid #154781;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.15);
  }

  .topbar__inner {
    height: var(--header-h);
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  /* Brand */
  .topbar__brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: #ffffff;
    text-decoration: none;
  }
  .topbar__brand:hover { color: #ffffff; text-decoration: none; }

  .topbar__logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: var(--radius-md);
  }

  .topbar__brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .topbar__brand-name {
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .topbar__brand-sub {
    font-size: 0.65rem;
    opacity: 0.75;
    margin-top: 2px;
    letter-spacing: 0.04em;
  }

  /* Nav */
  .topbar__nav {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .topbar__nav ul {
    display: flex;
    gap: 2px;
  }

  .topbar__nav a {
    display: inline-block;
    padding: 6px 12px;
    font-size: var(--font-size-sm);
    color: rgba(255, 255, 255, 0.92);
    border-radius: var(--radius-sm);
    transition: background var(--t-fast), color var(--t-fast);
  }
  .topbar__nav a:hover {
    background: rgba(255, 255, 255, 0.12);
    color: #ffffff;
    text-decoration: none;
  }

  /* Actions */
  .topbar__actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .topbar__status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 8px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-xs);
    color: rgba(255, 255, 255, 0.95);
  }

  .topbar__burger {
    display: none;
    width: 36px;
    height: 36px;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 4px;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: var(--radius-sm);
  }
  .topbar__burger span {
    display: block;
    width: 18px;
    height: 1.5px;
    background: #ffffff;
  }

  @media (max-width: 980px) {
    .topbar__nav,
    .topbar__actions {
      display: none;
    }
    .topbar__burger {
      display: flex;
      margin-left: auto;
    }
  }
</style>

<script is:inline>
  (function () {
    const el = document.getElementById('topbar-status-time');
    if (!el) return;
    const now = new Date();
    const time = now.toLocaleString('ru-RU', {
      day: '2-digit',
      month: '2-digit',
      hour: '2-digit',
      minute: '2-digit',
    });
    el.textContent = 'Рынок · ' + time + ' MSK';
  })();
</script>
