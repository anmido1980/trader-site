---
---

<section class="market-widget" id="market">
  <div class="market-widget__header">
    <span class="live-dot" aria-hidden="true"></span>
    <span class="market-widget__title">Рынок онлайн</span>
    <span class="market-widget__note">Данные TradingView</span>
  </div>

  <div class="market-widget__grid">
    {
      [
        { symbol: 'MOEX:IMOEX', label: 'Индекс Мосбиржи' },
        { symbol: 'FX_IDC:USDRUB', label: 'USD/RUB' },
        { symbol: 'FX_IDC:EURRUB', label: 'EUR/RUB' },
        { symbol: 'MOEX:SBER', label: 'Сбербанк' },
        { symbol: 'MOEX:GAZP', label: 'Газпром' },
        { symbol: 'MOEX:LKOH', label: 'Лукойл' },
        { symbol: 'MOEX:YDEX', label: 'Яндекс' },
        { symbol: 'TVC:UKOIL', label: 'Brent' },
      ].map((item) => (
        <div class="market-widget__card" data-symbol={item.symbol}>
          <div class="market-widget__label">{item.label}</div>
          <div class="tradingview-widget-container">
            <div class="tradingview-widget-container__widget"
              data-symbol={item.symbol}
              data-theme="dark"
              data-width="100%"
              data-height="120"
              data-interval="D"
              data-locale="ru"
              data-range="1M"
            ></div>
          </div>
        </div>
      ))
    }
  </div>
</section>

<script>
  (function () {
    const cards = document.querySelectorAll('.market-widget__card');
    if (!cards.length) return;

    const script = document.createElement('script');
    script.src = 'https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js';
    script.async = true;
    script.onload = () => {
      cards.forEach((card) => {
        const symbol = (card as HTMLElement).dataset.symbol;
        const container = card.querySelector('.tradingview-widget-container__widget');
        const tv = (window as any).TradingView;
        if (!symbol || !container || !tv) return;

        new tv.MiniSymbolOverviewWidget({
          container_id: container.id || undefined,
          symbol,
          width: '100%',
          height: 120,
          locale: 'ru',
          dateRange: '1M',
          colorTheme: 'dark',
          trendLineColor: 'rgba(41, 98, 255, 1)',
          underLineColor: 'rgba(41, 98, 255, 0.1)',
          underLineBottomColor: 'rgba(41, 98, 255, 0)',
          isTransparent: true,
          autosize: true,
          largeChartUrl: '',
        });
      });
    };
    document.head.appendChild(script);
  })();
</script>

<style>
  .market-widget {
    margin-top: var(--space-2);
  }

  .market-widget__header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: var(--space-2);
    padding: 0 4px;
  }

  .market-widget__title {
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .market-widget__note {
    margin-left: auto;
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }

  .live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-positive);
    animation: pulse 1.5s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .market-widget__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-2);
  }

  .market-widget__card {
    background: var(--color-bg-panel);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    padding: 12px;
    box-shadow: var(--shadow-panel);
  }

  .market-widget__label {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 6px;
  }

  .tradingview-widget-container {
    min-height: 120px;
  }

  @media (max-width: 1024px) {
    .market-widget__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 540px) {
    .market-widget__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
