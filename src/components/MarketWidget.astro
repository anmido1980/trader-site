---
import market from '../data/market.json';
import { sparkline } from '../utils/sparkline';

const date = new Date(market.updatedAt);
const updatedAt = date.toLocaleString('ru-RU', {
  day: '2-digit',
  month: '2-digit',
  hour: '2-digit',
  minute: '2-digit',
});
---

<section class="market-widget" id="market">
  <header class="market-widget__head">
    <div class="market-widget__title-wrap">
      <span class="live-dot" aria-hidden="true"></span>
      <h2 class="market-widget__title">Рынок онлайн</h2>
    </div>
    <span class="market-widget__updated">Обновлено {updatedAt} MSK · MOEX</span>
  </header>

  <div class="market-widget__body">
    <table class="market-table" aria-label="Актуальные котировки">
      <thead>
        <tr>
          <th class="market-table__name">Инструмент</th>
          <th class="market-table__num">Цена</th>
          <th class="market-table__num">Изм., %</th>
          <th class="market-table__chart">30 дней</th>
        </tr>
      </thead>
      <tbody>
        {
          market.items.map((item) => {
            const positive = item.changeValue >= 0;
            return (
              <tr>
                <td class="market-table__name">
                  <span class="market-table__label">{item.label}</span>
                  <span class="market-table__secid">{item.secid}</span>
                </td>
                <td class="market-table__num market-table__price">
                  <div>{item.price}</div>
                  {item.priceUsd && (
                    <div class="market-table__usd">{item.priceUsd}</div>
                  )}
                </td>
                <td class={`market-table__num ${positive ? 'delta-up' : 'delta-down'}`}>
                  {item.change}
                </td>
                <td class="market-table__chart">
                  {item.history.length > 1 ? (
                    <svg
                      viewBox="0 0 120 32"
                      width="120"
                      height="32"
                      class="sparkline"
                      preserveAspectRatio="none"
                      aria-hidden="true"
                    >
                      <path
                        d={sparkline(item.history, 120, 32)}
                        fill="none"
                        stroke={positive ? 'var(--color-positive)' : 'var(--color-negative)'}
                        stroke-width="1.5"
                      />
                    </svg>
                  ) : (
                    <span class="market-table__na">—</span>
                  )}
                </td>
              </tr>
            );
          })
        }
      </tbody>
    </table>
  </div>
</section>

<style>
  .market-widget {
    margin-top: var(--space-2);
  }

  .market-widget__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
    padding: 0 4px;
  }

  .market-widget__title-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .market-widget__title {
    font-size: var(--font-size-lg);
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0;
  }

  .market-widget__updated {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }

  .live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-positive);
    animation: pulse 1.5s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .market-widget__body {
    background: var(--color-bg-panel);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-panel);
    overflow: hidden;
  }

  .market-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--font-size-sm);
  }

  .market-table thead th {
    text-align: right;
    font-weight: 700;
    color: var(--color-text-secondary);
    background: var(--color-bg-panel-alt);
    padding: 10px 12px;
    border-bottom: 1px solid var(--color-border-light);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .market-table thead th.market-table__name { text-align: left; }
  .market-table thead th.market-table__chart { text-align: center; width: 130px; }

  .market-table tbody tr {
    transition: background var(--t-fast);
  }

  .market-table tbody tr:hover {
    background: var(--color-bg-row-hover);
  }

  .market-table tbody td {
    padding: 12px;
    border-bottom: 1px solid var(--color-border-light);
    text-align: right;
    vertical-align: middle;
  }

  .market-table tbody tr:last-child td { border-bottom: none; }

  .market-table__name {
    text-align: left !important;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .market-table__label {
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .market-table__secid {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }

  .market-table__price {
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .market-table__usd {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    font-weight: 400;
    margin-top: 2px;
  }

  .market-table__chart {
    text-align: center !important;
  }

  .sparkline {
    display: inline-block;
    vertical-align: middle;
  }

  .market-table__na {
    color: var(--color-text-muted);
  }

  @media (max-width: 720px) {
    .market-widget__head {
      flex-direction: column;
      align-items: flex-start;
      gap: 6px;
    }

    .market-table__secid {
      display: none;
    }
  }
</style>
