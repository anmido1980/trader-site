---
import market from '../data/market.json';
import { sparkline } from '../utils/sparkline';

interface MarketItem {
  secid: string;
  label: string;
  price: string;
  priceValue: number | null;
  change: string;
  changeValue: number;
  history: number[];
  priceUsd?: string;
  priceUsdUnit?: string;
  historyUsd?: number[];
  engine?: string;
  market?: string;
  decimals?: number;
}

const defaultEngines: Record<string, { engine: string; market: string; decimals: number }> = {
  IMOEX: { engine: 'stock', market: 'index', decimals: 2 },
  USD000UTSTOM: { engine: 'currency', market: 'selt', decimals: 4 },
  EUR_RUB__TOM: { engine: 'currency', market: 'selt', decimals: 4 },
  SBER: { engine: 'stock', market: 'shares', decimals: 2 },
  YDEX: { engine: 'stock', market: 'shares', decimals: 2 },
  GLDRUB_TOM: { engine: 'currency', market: 'selt', decimals: 2 },
  PLDRUB_TOM: { engine: 'currency', market: 'selt', decimals: 2 },
};

const typedItems = (market.items as MarketItem[]).map((item) => {
  const cfg = defaultEngines[item.secid] || { engine: 'stock', market: 'shares', decimals: 2 };
  return { ...item, ...cfg };
});

const date = new Date();
const updatedAt = date.toLocaleString('ru-RU', {
  day: '2-digit',
  month: '2-digit',
  hour: '2-digit',
  minute: '2-digit',
});

const clientItems = typedItems.map((item) => ({
  secid: item.secid,
  engine: item.engine,
  market: item.market,
  decimals: item.decimals,
}));
---

<section class="market-widget" id="market">
  <header class="market-widget__head">
    <div class="market-widget__title-wrap">
      <span class="live-dot" aria-hidden="true"></span>
      <h2 class="market-widget__title">Рынок онлайн</h2>
    </div>
    <span class="market-widget__updated" id="market-updated">Обновлено {updatedAt} MSK · MOEX</span>
  </header>

  <div class="market-widget__body">
    <table class="market-table" aria-label="Актуальные котировки">
      <thead>
        <tr>
          <th class="market-table__name">Инструмент</th>
          <th class="market-table__num">Цена</th>
          <th class="market-table__num">Изм., %</th>
          <th class="market-table__chart">30 дней</th>
        </tr>
      </thead>
      <tbody>
        {
          typedItems.map((item) => {
            const positive = item.changeValue >= 0;
            const sparklineHistory = item.historyUsd ?? item.history;
            return (
              <tr data-secid={item.secid}>
                <td class="market-table__name">
                  <span class="market-table__label">{item.label}</span>
                  <span class="market-table__secid">{item.secid}</span>
                </td>
                <td class="market-table__num market-table__price" data-field="price">
                  <div>{item.price}</div>
                  {item.priceUsd && (
                    <div class="market-table__usd" data-field="priceUsd">
                      {item.priceUsd}
                      {item.priceUsdUnit && <span class="market-table__unit"> {item.priceUsdUnit}</span>}
                    </div>
                  )}
                </td>
                <td
                  class={`market-table__num ${positive ? 'delta-up' : 'delta-down'}`}
                  data-field="change"
                >
                  {item.change}
                </td>
                <td class="market-table__chart" data-field="chart">
                  {item.history.length > 1 ? (
                    <svg
                      viewBox="0 0 120 32"
                      width="120"
                      height="32"
                      class="sparkline"
                      preserveAspectRatio="none"
                      aria-hidden="true"
                    >
                      <path
                        d={sparkline(sparklineHistory, 120, 32)}
                        fill="none"
                        stroke={positive ? 'var(--color-positive)' : 'var(--color-negative)'}
                        stroke-width="1.5"
                      />
                    </svg>
                  ) : (
                    <span class="market-table__na">—</span>
                  )}
                </td>
              </tr>
            );
          })
        }
      </tbody>
    </table>
  </div>
</section>

<script define:vars={{ clientItems }} type="module" is:inline>
  function buildSparklinePath(values, w, h) {
    if (!values || values.length === 0) return '';
    const min = Math.min(...values);
    const max = Math.max(...values);
    const range = max - min || 1;
    const stepX = w / (values.length - 1 || 1);
    const padY = 2;
    const innerH = h - padY * 2;
    return values
      .map((v, i) => {
        const x = i * stepX;
        const y = padY + (1 - (v - min) / range) * innerH;
        return `${i === 0 ? 'M' : 'L'} ${x.toFixed(1)} ${y.toFixed(1)}`;
      })
      .join(' ');
  }

  function formatNumber(value, decimals) {
    if (value === null || value === undefined || Number.isNaN(value)) return '—';
    return value.toLocaleString('ru-RU', {
      minimumFractionDigits: decimals,
      maximumFractionDigits: decimals,
    });
  }

  function findValue(data, columns, name) {
    const idx = columns.indexOf(name);
    return idx >= 0 ? data[idx] : undefined;
  }

  function parseIssResponse(json) {
    const md = json.marketdata || json.securities;
    if (!md || !md.data || md.data.length === 0) return null;
    const columns = md.columns || [];
    const row = md.data[0];
    const last =
      findValue(row, columns, 'LAST') ??
      findValue(row, columns, 'LCURRENTPRICE') ??
      findValue(row, columns, 'MARKETPRICE') ??
      findValue(row, columns, 'MARKETPRICETODAY') ??
      findValue(row, columns, 'CURRENTVALUE') ??
      findValue(row, columns, 'LASTVALUE');
    const prev = findValue(row, columns, 'PREVPRICE') ?? findValue(row, columns, 'OPENVALUE');
    const changePrc =
      findValue(row, columns, 'LASTTOPREVPRICE') ??
      findValue(row, columns, 'LASTCHANGEPRCNT') ??
      findValue(row, columns, 'LASTCHANGETOOPENPRCNT');
    return { last, prev, changePrc };
  }

  function parseHistoryResponse(json) {
    const hist = json.history;
    if (!hist || !hist.data) return [];
    const columns = hist.columns || [];
    const closeIdx = columns.indexOf('CLOSE');
    const legalCloseIdx = columns.indexOf('LEGALCLOSEPRICE');
    const idx = closeIdx >= 0 ? closeIdx : legalCloseIdx >= 0 ? legalCloseIdx : -1;
    if (idx < 0) return [];
    return hist.data.map((row) => row[idx]).filter((v) => v !== null && v !== undefined);
  }

  async function fetchQuote(item) {
    const url = `https://iss.moex.com/iss/engines/${item.engine}/markets/${item.market}/securities/${item.secid}.json`;
    const res = await fetch(url);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    return parseIssResponse(await res.json());
  }

  async function fetchHistory(item) {
    const till = new Date();
    const from = new Date(till);
    from.setDate(from.getDate() - 30);
    const fmt = (d) => d.toISOString().split('T')[0];
    const url = `https://iss.moex.com/iss/history/engines/${item.engine}/markets/${item.market}/securities/${item.secid}.json?from=${fmt(from)}&till=${fmt(till)}`;
    const res = await fetch(url);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    return parseHistoryResponse(await res.json());
  }

  async function updateRow(item) {
    const row = document.querySelector(`tr[data-secid="${item.secid}"]`);
    if (!row) return;

    const [quote, history] = await Promise.all([fetchQuote(item), fetchHistory(item)]);
    if (!quote) return;

    const price = quote.last;
    let changeValue = 0;
    if (quote.changePrc !== null && quote.changePrc !== undefined) {
      changeValue = Number(quote.changePrc);
    } else if (quote.prev) {
      changeValue = ((Number(price) - Number(quote.prev)) / Number(quote.prev)) * 100;
    }

    const positive = changeValue >= 0;
    const sign = positive ? '+' : '';

    const priceCell = row.querySelector('[data-field="price"]');
    if (priceCell) {
      const firstDiv = priceCell.querySelector('div');
      if (firstDiv) firstDiv.textContent = formatNumber(Number(price), item.decimals);
    }

    const changeCell = row.querySelector('[data-field="change"]');
    if (changeCell) {
      changeCell.textContent = `${sign}${changeValue.toFixed(2)}%`;
      changeCell.classList.remove('delta-up', 'delta-down');
      changeCell.classList.add(positive ? 'delta-up' : 'delta-down');
    }

    const chartCell = row.querySelector('[data-field="chart"]');
    if (chartCell && history.length > 1) {
      const pathD = buildSparklinePath(history, 120, 32);
      chartCell.innerHTML = `<svg viewBox="0 0 120 32" width="120" height="32" class="sparkline" preserveAspectRatio="none" aria-hidden="true"><path d="${pathD}" fill="none" stroke="var(--color-${positive ? 'positive' : 'negative'})" stroke-width="1.5" /></svg>`;
    }
  }

  async function refresh() {
    const updated = document.getElementById('market-updated');
    const now = new Date();
    const time = now.toLocaleString('ru-RU', {
      day: '2-digit',
      month: '2-digit',
      hour: '2-digit',
      minute: '2-digit',
    });

    const results = await Promise.allSettled(clientItems.map(updateRow));
    const failed = results.filter((r) => r.status === 'rejected').length;

    if (updated) {
      updated.textContent = failed === results.length
        ? `Обновлено ${time} MSK · MOEX (данные отложены)`
        : `Обновлено ${time} MSK · MOEX`;
    }
  }

  if (typeof window !== 'undefined') {
    refresh();
    setInterval(refresh, 5 * 60 * 1000);
  }
</script>

<style>
  .market-widget {
    margin-top: var(--space-2);
  }

  .market-widget__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
    padding: 0 4px;
  }

  .market-widget__title-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .market-widget__title {
    font-size: var(--font-size-lg);
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0;
  }

  .market-widget__updated {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }

  .live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-positive);
    animation: pulse 1.5s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .market-widget__body {
    background: var(--color-bg-panel);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-panel);
    overflow: hidden;
  }

  .market-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--font-size-sm);
  }

  .market-table thead th {
    text-align: right;
    font-weight: 700;
    color: var(--color-text-secondary);
    background: var(--color-bg-panel-alt);
    padding: 10px 12px;
    border-bottom: 1px solid var(--color-border-light);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .market-table thead th.market-table__name { text-align: left; }
  .market-table thead th.market-table__chart { text-align: center; width: 130px; }

  .market-table tbody tr {
    transition: background var(--t-fast);
  }

  .market-table tbody tr:hover {
    background: var(--color-bg-row-hover);
  }

  .market-table tbody td {
    padding: 12px;
    border-bottom: 1px solid var(--color-border-light);
    text-align: right;
    vertical-align: middle;
  }

  .market-table tbody tr:last-child td { border-bottom: none; }

  .market-table__name {
    text-align: left !important;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .market-table__label {
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .market-table__secid {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }

  .market-table__price {
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .market-table__usd {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    font-weight: 400;
    margin-top: 2px;
  }

  .market-table__unit {
    color: var(--color-text-muted);
  }

  .market-table__chart {
    text-align: center !important;
  }

  .sparkline {
    display: inline-block;
    vertical-align: middle;
  }

  .market-table__na {
    color: var(--color-text-muted);
  }

  @media (max-width: 720px) {
    .market-widget__head {
      flex-direction: column;
      align-items: flex-start;
      gap: 6px;
    }

    .market-table__secid {
      display: none;
    }
  }
</style>
