---
const symbols = [
  { proName: 'MOEX:IMOEX', title: 'Индекс Мосбиржи' },
  { proName: 'FX_IDC:USDRUB', title: 'USD/RUB' },
  { proName: 'FX_IDC:EURRUB', title: 'EUR/RUB' },
  { proName: 'MOEX:SBER', title: 'Сбербанк' },
  { proName: 'MOEX:GAZP', title: 'Газпром' },
  { proName: 'MOEX:LKOH', title: 'Лукойл' },
  { proName: 'MOEX:YDEX', title: 'Яндекс' },
  { proName: 'TVC:UKOIL', title: 'Brent' },
];

const config = JSON.stringify({
  symbols: symbols.map((s) => s),
  showSymbolLogo: true,
  isTransparent: false,
  displayMode: 'adaptive',
  colorTheme: 'dark',
  locale: 'ru',
});
---

<section class="market-widget" id="market">
  <div class="market-widget__header">
    <span class="live-dot" aria-hidden="true"></span>
    <span class="market-widget__title">Рынок онлайн</span>
    <span class="market-widget__note">Данные TradingView</span>
  </div>

  <div class="tradingview-widget-container">
    <div class="tradingview-widget-container__widget"></div>
    <div class="tradingview-widget-copyright">
      <a href="https://www.tradingview.com/" rel="noopener nofollow" target="_blank">
        <span class="blue-text">Тикеры рынка</span>
      </a>
    </div>
    <script
      type="text/javascript"
      src="https://s3.tradingview.com/external-embedding/embed-widget-ticker-tape.js"
      async
    >
      {config}
    </script>
  </div>
</section>

<style>
  .market-widget {
    margin-top: var(--space-2);
  }

  .market-widget__header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: var(--space-2);
    padding: 0 4px;
  }

  .market-widget__title {
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .market-widget__note {
    margin-left: auto;
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }

  .live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-positive);
    animation: pulse 1.5s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .tradingview-widget-container {
    min-height: 60px;
    background: #131722;
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    overflow: hidden;
    padding: 6px 0;
  }

  .tradingview-widget-container iframe {
    display: block;
    width: 100% !important;
    height: 60px !important;
  }

  .tradingview-widget-copyright {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    text-align: center;
    padding-top: 4px;
  }

  .tradingview-widget-copyright a {
    color: var(--color-text-muted);
  }

  .blue-text {
    color: var(--color-accent);
  }
</style>
