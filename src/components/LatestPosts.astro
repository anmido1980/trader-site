---
import { getPosts } from '../utils/posts';
import PostCard from './PostCard.astro';

const posts = await getPosts();
const latest = posts.slice(0, 3);
---

<section class="latest-posts" id="posts">
  <div class="container">
    <div class="latest-posts__head">
      <div>
        <span class="eyebrow">// 03 · Материалы</span>
        <h2 class="latest-posts__title">Последние разборы</h2>
      </div>
      <a href="/posts/" class="btn btn--secondary btn--sm">Все материалы →</a>
    </div>

    {latest.length > 0 ? (
      <div class="latest-posts__grid">
        {latest.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    ) : (
      <p class="latest-posts__empty">Пока нет опубликованных материалов.</p>
    )}
  </div>
</section>

<style>
  .latest-posts {
    padding: var(--space-6) 0;
    background: var(--color-bg-page);
  }
  .latest-posts__head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }
  .latest-posts__title {
    font-size: var(--font-size-3xl);
    margin: var(--space-3) 0 0;
    line-height: 1.15;
  }
  .latest-posts__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  .latest-posts__empty {
    color: var(--color-text-secondary);
    font-size: var(--font-size-md);
  }
  @media (max-width: 1000px) {
    .latest-posts__grid {
      grid-template-columns: 1fr;
    }
    .latest-posts__head {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
