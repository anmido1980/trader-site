---
import rubrics from '../data/rubrics.json';
---

<section class="rubrics" id="rubrics">
  <div class="container">
    <div class="rubrics__head">
      <div>
        <span class="eyebrow">// 02 · Рубрики</span>
        <h2 class="rubrics__title">Две рубрики — два уровня погружения</h2>
      </div>
      <p class="rubrics__sub">
        На канале представлены две рубрики. Выбирайте ту, что отвечает вашему
        текущему уровню — или читайте обе: они дополняют друг друга.
      </p>
    </div>

    <div class="rubrics__grid">
      {rubrics.rubrics.map((r, idx) => (
        <article class={`panel rubric-card rubric-card--${r.id}`} id={r.id} data-reveal>
          <header class="panel__head">
            <h3>
              <span class="rubric-card__index num">0{idx + 1}</span>
              {r.title}
            </h3>
            <span class={`rubric-card__level rubric-card__level--${r.metrics.level}`}>
              {r.metrics.level === 'starter' ? 'STARTER' : 'ADVANCED'}
            </span>
          </header>

          <div class="panel__body">
            <p class="rubric-card__lead">{r.lead}</p>

            <h4 class="rubric-card__subhead">Темы рубрики</h4>
            <ul class="rubric-card__topics">
              {r.topics.map((t) => (
                <li>
                  <span class="rubric-card__check" aria-hidden="true">✓</span>
                  <span>{t}</span>
                </li>
              ))}
            </ul>
          </div>

          <footer class="rubric-card__foot">
            <div class="rubric-card__metrics">
              <div class="rubric-card__metric">
                <span class="num">{r.metrics.materials}</span>
                <span>материалов</span>
              </div>
              <div class="rubric-card__metric">
                <span class="num">~{r.metrics.readTime}</span>
                <span>ридинг</span>
              </div>
              <div class="rubric-card__metric">
                <span class="num">{idx === 0 ? 'Начинающий' : 'Практик'}</span>
                <span>уровень</span>
              </div>
            </div>
            <a href="#subscribe" class="btn btn--primary btn--sm">
              Подписаться на рубрику →
            </a>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .rubrics {
    padding: var(--space-6) 0 var(--space-7);
    background: var(--color-bg-page);
  }

  .rubrics__head {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-5);
    align-items: end;
    margin-bottom: var(--space-4);
  }

  .rubrics__title {
    font-size: var(--font-size-3xl);
    margin: var(--space-3) 0 0;
    line-height: 1.15;
  }

  .rubrics__sub {
    color: var(--color-text-secondary);
    font-size: var(--font-size-md);
    line-height: 1.6;
  }

  .rubrics__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .rubric-card {
    display: flex;
    flex-direction: column;
  }

  .rubric-card .panel__head {
    align-items: center;
  }

  .rubric-card .panel__head h3 {
    display: flex;
    align-items: baseline;
    gap: 10px;
    font-size: var(--font-size-md);
  }

  .rubric-card__index {
    color: var(--color-accent);
    font-weight: 700;
    font-size: var(--font-size-xs);
    background: var(--color-accent-light);
    border-radius: var(--radius-sm);
    padding: 3px 7px;
  }

  .rubric-card__level {
    display: inline-block;
    font-size: var(--font-size-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 3px 8px;
    border-radius: var(--radius-sm);
    border: 1px solid currentColor;
  }

  .rubric-card__level--starter {
    color: var(--color-text-secondary);
  }

  .rubric-card__level--advanced {
    color: var(--color-accent);
    background: var(--color-accent-light);
  }

  .rubric-card__lead {
    font-size: var(--font-size-md);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px dashed var(--color-border-light);
  }

  .rubric-card__subhead {
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
    font-weight: 700;
  }

  .rubric-card__topics {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .rubric-card__topics li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: var(--font-size-sm);
    color: var(--color-text-primary);
    line-height: 1.5;
  }

  .rubric-card__check {
    color: var(--color-accent);
    font-weight: 700;
    flex-shrink: 0;
  }

  .rubric-card__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: 14px 16px;
    border-top: 1px solid var(--color-border-light);
    background: var(--color-bg-panel-alt);
    border-bottom-left-radius: var(--radius-md);
    border-bottom-right-radius: var(--radius-md);
  }

  .rubric-card__metrics {
    display: flex;
    gap: var(--space-5);
  }

  .rubric-card__metric {
    display: flex;
    flex-direction: column;
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }

  .rubric-card__metric .num {
    font-size: var(--font-size-md);
    font-weight: 700;
    color: var(--color-text-primary);
  }

  @media (max-width: 1000px) {
    .rubrics__head {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }
    .rubrics__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .rubric-card__foot {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
